{
  "buildCommand": "node build_all_institutes.js gs1 && node build_all_institutes.js csat",
  "outputDirectory": "dist",
  "installCommand": "echo skip",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "routes": [
    { "src": "/gs1", "dest": "/all-institutes-gs1-score-checker.html" },
    { "src": "/csat", "dest": "/all-institutes-csat-score-checker.html" },
    { "src": "/prelims_2026_gs_paper.html", "dest": "/prelims_2026_gs_paper.html" },
    { "src": "/prelims_2026_institute_key_comparison.html", "dest": "/prelims_2026_institute_key_comparison.html" },
    { "src": "/prelims_2026_csat_key_comparison.html", "dest": "/prelims_2026_csat_key_comparison.html" },
    { "src": "/prelims_2026_CSAT_paper.html", "dest": "/prelims_2026_CSAT_paper.html" },
    { "src": "/prelims_2026_subject_analysis.html", "dest": "/prelims_2026_subject_analysis.html" },
    { "src": "/total-qns-attempt-planner.html", "dest": "/total-qns-attempt-planner.html" },
    { "src": "/upsc_prelims_cutoff.html", "dest": "/upsc_prelims_cutoff.html" },
    { "src": "/gs_prelims_pyqs_question_bank.html", "dest": "/gs_prelims_pyqs_question_bank.html" },
    { "src": "/gs_mains_pyqs_question_bank.html", "dest": "/gs_mains_pyqs_question_bank.html" },
    { "src": "/prelims_2026_gs_paper_Question_types.html", "dest": "/prelims_2026_gs_paper_Question_types.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
